# 百度翻译开放平台 https://fanyi-api.baidu.com/
VITE_BAIDU_APP_ID=
VITE_BAIDU_SECRET=

# 生产环境（GitHub Pages 等）必填：可访问的「转发百度翻译 POST」的地址。
# 本地开发可不填，使用 Vite 代理 /baidu-fanyi。
# 可用仓库内 workers/ 部署 Cloudflare Worker，把 Worker 的 https URL 填在这里。
# GitHub Actions 请在仓库 Settings → Secrets 中同样配置以上三项（名称一致）。
# VITE_BAIDU_TRANSLATE_URL=https://你的-worker.workers.dev

# 可选：全站统计（PV/UV）接口；不填则使用「翻译 Worker 根 URL + /stats」（需按 workers/README.md 绑定 KV）
# VITE_SITE_STATS_URL=https://你的-worker.workers.dev/stats
