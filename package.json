{
  "name": "jsoncc-lab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "tsx scripts/generate-blog-meta.ts",
    "dev": "vite",
    "prebuild": "tsx scripts/generate-blog-meta.ts",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "workers:dev": "wrangler dev --config workers/wrangler.toml",
    "workers:deploy": "wrangler deploy --config workers/wrangler.toml",
    "workers:kv-bind": "node scripts/worker-kv-bind.mjs"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "marked": "^17.0.5",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vite": "^5.0.0",
    "vue-tsc": "^2.1.10",
    "wrangler": "^3.114.1"
  }
}
