{
  "name": "jsoncc-lab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "tsx scripts/generate-blog-meta.ts",
    "dev": "vite",
    "prebuild": "tsx scripts/generate-blog-meta.ts",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "workers:dev": "wrangler dev --config workers/wrangler.toml",
    "workers:deploy": "wrangler deploy --config workers/wrangler.toml",
    "workers:kv-bind": "tsx scripts/worker-kv-bind.ts",
    "history:generate": "tsx scripts/generate-history-daily.ts",
    "history:send-mail": "tsx scripts/send-history-mail.ts",
    "history:daily": "npm run history:generate && npm run history:send-mail"
  },
  "dependencies": {
    "@iconify-icons/mdi": "^1.2.48",
    "@iconify-icons/radix-icons": "^1.2.9",
    "@iconify/vue": "^5.0.0",
    "crypto-js": "^4.2.0",
    "lunar-javascript": "^1.7.7",
    "lunar-typescript": "^1.8.6",
    "marked": "^17.0.5",
    "nodemailer": "^7.0.9",
    "solarlunar": "^3.1.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^7.0.3",
    "@vitejs/plugin-vue": "^5.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vite": "^5.0.0",
    "vue-tsc": "^2.1.10",
    "wrangler": "^3.114.1"
  }
}
